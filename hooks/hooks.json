{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-pr-check.sh",
            "statusMessage": "PR前チェック: format & lint を実行中...",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
